{
  "ConnectionStrings": {
    "Default": "server=127.0.0.1;port=3306;database=board_exam;user=root;password="
  },
  "Jwt": {
    "Issuer": "BoardExam.Api",
    "Audience": "BoardExam.Client",
    "Key": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_123456789",
    "ExpiryHours": 24
  },
  "Frontend": {
    "Origin": "http://localhost:3000"
  },
  "DatabaseResilience": {
    "EfMaxRetryCount": 5,
    "EfMaxRetryDelaySeconds": 10,
    "StartupRetryDelaySeconds": 5,
    "HealthCheckIntervalSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
